# ============================================
# Configurare Smart Product Scraper
# ============================================
# Copiați acest fișier ca .env și completați valorile:
#   cp .env.example .env
#
# IMPORTANT: Fișierul .env conține date sensibile (chei API)
# și NU trebuie inclus în Git (este deja în .gitignore).
# ============================================

# === Cheie API OpenAI (pentru metoda LLM cu GPT-4o-mini) ===
# Obțineți o cheie de la: https://platform.openai.com/api-keys
OPENAI_API_KEY=

# === Cheie API Anthropic (pentru metoda LLM cu Claude Haiku) ===
# Obțineți o cheie de la: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=
